# Backend runtime — copy to .env, never commit .env itself.

# ─── HTTP ──────────────────────────────────────────────
PORT=4000
BASE_URL=http://localhost:4000
FRONTEND_ORIGIN=http://localhost:5173

# ─── Session ───────────────────────────────────────────
# Generate a 32-byte hex secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-real-32-byte-hex-string-please

# ─── Database (Prisma) ─────────────────────────────────
# SQLite for dev; swap to postgresql://... in prod per ADR-0002
DATABASE_URL="file:./dev.db"

# ─── Google OAuth ──────────────────────────────────────
# Create these in Google Cloud Console → APIs & Services → Credentials
# See Docs/google-cloud-setup.md for the setup checklist
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback

# ─── Token encryption ──────────────────────────────────
# OAuth tokens are encrypted at rest per delivery.md §Internals.
# Generate a 32-byte hex key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=change-me-to-a-real-32-byte-hex-key-please
